# Example environment variables for a MongoDB-backed setup
# Do NOT commit real credentials to source control.

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/mydatabase?retryWrites=true&w=majority

# Optional: explicit database name (some drivers use the database in the URI)
MONGODB_DB_NAME=mydatabase

# Port for a local backend API (if you add one)
PORT=4000

# Notes:
# - This is a frontend repository; the frontend should not connect directly to MongoDB.
# - Create a small backend (Express, Fastify, Nest, etc.) that reads `MONGODB_URI` and
#   exposes secure HTTP endpoints for the front-end to consume.
